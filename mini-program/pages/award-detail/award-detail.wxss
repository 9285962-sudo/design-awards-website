/* 奖项详情页样式 */

/* 头部 */
.header {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  margin: -20rpx -30rpx 30rpx;
  padding: 60rpx 30rpx 40rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.header::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(102, 126, 234, 0.3) 0%, transparent 70%);
  border-radius: 50%;
}

.award-logo-large {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 30rpx;
  position: relative;
  z-index: 1;
  box-shadow: 0 20rpx 60rpx rgba(102, 126, 234, 0.4);
}

.logo-text-large {
  font-size: 80rpx;
  font-weight: 700;
  color: #fff;
}

.award-name-large {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
  position: relative;
  z-index: 1;
}

.award-name-en-large {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.award-tags {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  position: relative;
  z-index: 1;
}

/* 费用时间线 */
.fee-timeline {
  padding: 10rpx 0;
}

.fee-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  position: relative;
}

.fee-item:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 16rpx;
  top: 50rpx;
  bottom: -10rpx;
  width: 2rpx;
  background: #e8e8e8;
}

.fee-item.active .fee-dot {
  background: #667eea;
  box-shadow: 0 0 0 8rpx rgba(102, 126, 234, 0.2);
}

.fee-item.expired .fee-dot {
  background: #ccc;
}

.fee-item.expired .fee-content {
  opacity: 0.5;
}

.fee-dot {
  width: 32rpx;
  height: 32rpx;
  background: #667eea;
  border-radius: 50%;
  margin-right: 24rpx;
  flex-shrink: 0;
  margin-top: 6rpx;
}

.fee-content {
  flex: 1;
}

.fee-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.fee-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.fee-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
}

.fee-item.expired .fee-status {
  background: #f0f0f0;
  color: #999;
}

.fee-details {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.fee-amount {
  font-size: 36rpx;
  font-weight: 700;
  color: #667eea;
}

.fee-deadline {
  font-size: 26rpx;
  color: #666;
}

.fee-note {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding: 20rpx;
  background: rgba(102, 126, 234, 0.05);
  border-radius: 12rpx;
}

.note-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.note-text {
  font-size: 26rpx;
  color: #667eea;
}

/* 时间线 */
.timeline {
  padding: 10rpx 0;
}

.timeline-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.timeline-item:last-child {
  border-bottom: none;
}

.timeline-item.highlight {
  background: rgba(245, 87, 108, 0.05);
  margin: 0 -20rpx;
  padding: 20rpx;
  border-radius: 12rpx;
}

.timeline-item.highlight .timeline-label {
  color: #f5576c;
  font-weight: 600;
}

.timeline-item.highlight .timeline-value {
  color: #f5576c;
  font-weight: 600;
}

.timeline-label {
  font-size: 28rpx;
  color: #666;
}

.timeline-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 类别列表 */
.category-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-item {
  background: rgba(102, 126, 234, 0.1);
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.category-name {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 500;
}

.category-count {
  font-size: 22rpx;
  color: #999;
  background: #fff;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

/* 要求列表 */
.requirement-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.requirement-item {
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 12rpx;
}

.req-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.req-value {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 规格部分 */
.spec-section {
  margin-bottom: 30rpx;
}

.spec-section:last-child {
  margin-bottom: 0;
}

.spec-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.spec-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.spec-item {
  font-size: 28rpx;
  color: #666;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.spec-item:last-child {
  border-bottom: none;
}

/* 评审标准 */
.criteria-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.criteria-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.criteria-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.criteria-name {
  font-size: 28rpx;
  color: #333;
}

.criteria-weight {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 600;
}

.progress-bar {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  border-radius: 4rpx;
}

/* 奖项等级 */
.level-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.level-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.level-badge {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.level-desc {
  font-size: 26rpx;
  color: #666;
  flex: 1;
}

/* 权益列表 */
.benefit-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.benefit-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.benefit-icon {
  width: 36rpx;
  height: 36rpx;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #667eea;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.benefit-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  flex: 1;
}

/* 专家建议卡片 */
.expert-card {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
  border: 2rpx solid rgba(102, 126, 234, 0.2);
}

.expert-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.expert-section {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.expert-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #667eea;
}

.expert-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.tip-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tip-item {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

/* 底部按钮 */
.footer-actions {
  display: flex;
  gap: 20rpx;
  margin: 40rpx 0;
}

.footer-actions .btn-outline,
.footer-actions .btn-gradient {
  flex: 1;
}

/* 链接样式 */
.link {
  color: #667eea;
  text-decoration: underline;
}
