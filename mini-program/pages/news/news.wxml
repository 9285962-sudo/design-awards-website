<!-- 新闻文章列表页 -->
<view class="container">
  <!-- 顶部Banner -->
  <view class="banner">
    <view class="banner-content">
      <text class="banner-title">赛事动态</text>
      <text class="banner-subtitle">设计能 · 让设计被看见</text>
    </view>
  </view>

  <!-- Tab切换 -->
  <view class="tabs">
    <view 
      class="tab {{currentTab === 'news' ? 'active' : ''}}" 
      bindtap="switchTab" 
      data-tab="news"
    >
      新闻动态
    </view>
    <view 
      class="tab {{currentTab === 'strategy' ? 'active' : ''}}" 
      bindtap="switchTab" 
      data-tab="strategy"
    >
      参赛策略
    </view>
  </view>

  <!-- 文章列表 -->
  <view class="article-list">
    <block wx:if="{{loading}}">
      <view class="loading">
        <text>加载中...</text>
      </view>
    </block>
    <block wx:elif="{{articles.length > 0}}">
      <view 
        class="article-item" 
        wx:for="{{articles}}" 
        wx:key="id"
        bindtap="goToArticle" 
        data-id="{{item.id}}"
        data-type="{{currentTab}}"
      >
        <view class="article-cover" wx:if="{{item.cover}}">
          <image src="{{item.cover}}" mode="aspectFill" />
        </view>
        <view class="article-info">
          <view class="article-category {{currentTab}}">
            {{currentTab === 'news' ? item.category : item.category}}
          </view>
          <view class="article-title">{{item.title}}</view>
          <view class="article-meta">
            <text class="date">{{item.publishTime}}</text>
            <text class="author">{{item.author}}</text>
          </view>
        </view>
      </view>
    </block>
    <block wx:else>
      <view class="empty">
        <text>暂无文章</text>
      </view>
    </block>
  </view>
</view>
