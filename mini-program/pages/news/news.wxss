/* 新闻文章列表页样式 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* Banner */
.banner {
  background: linear-gradient(135deg, #1E3A5F 0%, #2d5a8e 100%);
  padding: 40rpx 30rpx;
  color: #fff;
}

.banner-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.banner-subtitle {
  display: block;
  font-size: 24rpx;
  opacity: 0.8;
}

/* Tab切换 */
.tabs {
  display: flex;
  background-color: #fff;
  padding: 0 30rpx;
  border-bottom: 1rpx solid #eee;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab.active {
  color: #1E3A5F;
  font-weight: bold;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #1E3A5F;
  border-radius: 2rpx;
}

/* 文章列表 */
.article-list {
  padding: 20rpx 30rpx;
}

.article-item {
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.article-cover {
  width: 100%;
  height: 320rpx;
}

.article-cover image {
  width: 100%;
  height: 100%;
}

.article-info {
  padding: 24rpx;
}

.article-category {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
  margin-bottom: 12rpx;
}

.article-category.news {
  background-color: #E8F4FF;
  color: #1E3A5F;
}

.article-category.strategy {
  background-color: #FFF8E8;
  color: #B8860B;
}

.article-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.5;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.article-meta {
  display: flex;
  font-size: 22rpx;
  color: #999;
}

.article-meta .date {
  margin-right: 20rpx;
}

/* 加载状态 */
.loading, .empty {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}
