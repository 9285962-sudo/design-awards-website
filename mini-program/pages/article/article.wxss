/* 文章详情页样式 */
.container {
  min-height: 100vh;
  background-color: #fff;
  padding-bottom: 120rpx;
}

/* 文章头部 */
.article-header {
  padding: 40rpx 30rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}

.article-meta {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.category {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 4rpx;
  margin-right: 20rpx;
}

.category.news {
  background-color: #E8F4FF;
  color: #1E3A5F;
}

.category.strategy {
  background-color: #FFF8E8;
  color: #B8860B;
}

.date {
  font-size: 24rpx;
  color: #999;
}

.article-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.article-author {
  font-size: 24rpx;
  color: #666;
}

/* 封面图 */
.article-cover {
  width: 100%;
  background-color: #f5f5f5;
}

.article-cover image {
  width: 100%;
  display: block;
}

/* 文章正文 */
.article-body {
  padding: 30rpx;
}

.article-content {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
}

/* 处理HTML标签样式 */
.article-content p {
  margin-bottom: 24rpx;
  text-align: justify;
}

.article-content h2 {
  font-size: 34rpx;
  font-weight: bold;
  color: #1E3A5F;
  margin: 40rpx 0 20rpx;
}

.article-content h3 {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin: 30rpx 0 16rpx;
}

.article-content img {
  max-width: 100%;
  height: auto;
  border-radius: 8rpx;
  margin: 20rpx 0;
  display: block;
}

.article-content a {
  color: #1E3A5F;
  text-decoration: underline;
}

.article-content strong {
  font-weight: bold;
  color: #1E3A5F;
}

/* 加载和错误状态 */
.loading, .error {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.error {
  color: #e74c3c;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 30rpx;
  background-color: #fff;
  border-top: 1rpx solid #eee;
  justify-content: space-between;
}

.back-btn, .share-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.back-btn {
  background-color: #f5f5f5;
  color: #333;
  margin-right: 20rpx;
}

.share-btn {
  background-color: #1E3A5F;
  color: #fff;
}
