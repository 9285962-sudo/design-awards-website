/* 申报服务页样式 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 140rpx;
}

.banner {
  background: linear-gradient(135deg, #1E3A5F 0%, #2d5a8e 100%);
  padding: 50rpx 30rpx;
  color: #fff;
  text-align: center;
}

.banner-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.banner-subtitle {
  display: block;
  font-size: 24rpx;
  opacity: 0.85;
}

.stats-row {
  display: flex;
  background-color: #fff;
  padding: 30rpx 0;
  margin: -30rpx 30rpx 0;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  position: relative;
  top: -30rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #1E3A5F;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  background-color: #eee;
  margin: 10rpx 0;
}

.section {
  background-color: #fff;
  margin: 24rpx 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1E3A5F;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #1E3A5F;
}

.process-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.process-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.process-num {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #1E3A5F, #2d5a8e);
  color: #fff;
  border-radius: 50%;
  text-align: center;
  line-height: 48rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.process-info {
  flex: 1;
}

.process-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.process-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
}

.scope-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.scope-item {
  padding: 12rpx 24rpx;
  background-color: #f0f7ff;
  color: #1E3A5F;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.value-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.value-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.value-icon {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  background-color: #FFF3E0;
  color: #E65100;
  border-radius: 50%;
  text-align: center;
  line-height: 48rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.value-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.contact-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-top: 1rpx solid #eee;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.08);
}

.contact-btn, .contact-phone {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 24rpx 0;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.contact-btn {
  background: linear-gradient(135deg, #1E3A5F, #2d5a8e);
  color: #fff;
}

.contact-phone {
  background-color: #f0f0f0;
  color: #333;
}

.contact-icon {
  font-size: 32rpx;
}
