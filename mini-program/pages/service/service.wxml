<!-- 申报服务页 -->
<view class="container">
  <!-- Banner -->
  <view class="banner">
    <view class="banner-content">
      <text class="banner-title">申报服务</text>
      <text class="banner-subtitle">设计能 · 10年+经验 · 108个全球大奖</text>
    </view>
  </view>

  <!-- 核心数据 -->
  <view class="stats-row">
    <view class="stat-item">
      <view class="stat-num">108+</view>
      <view class="stat-label">合作奖项</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-num">350+</view>
      <view class="stat-label">服务设计师</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-num">80%</view>
      <view class="stat-label">平均获奖率</view>
    </view>
  </view>

  <!-- 服务流程 -->
  <view class="section">
    <view class="section-title">服务流程</view>
    <view class="process-list">
      <view class="process-item" wx:for="{{processSteps}}" wx:key="index">
        <view class="process-num">{{index + 1}}</view>
        <view class="process-info">
          <view class="process-name">{{item.name}}</view>
          <view class="process-desc">{{item.desc}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 服务范围 -->
  <view class="section">
    <view class="section-title">服务范围</view>
    <view class="scope-grid">
      <view class="scope-item" wx:for="{{scopes}}" wx:key="index">{{item}}</view>
    </view>
  </view>

  <!-- 增值服务 -->
  <view class="section">
    <view class="section-title">增值服务</view>
    <view class="value-list">
      <view class="value-item" wx:for="{{valueServices}}" wx:key="index">
        <view class="value-icon">{{index + 1}}</view>
        <view class="value-text">{{item}}</view>
      </view>
    </view>
  </view>

  <!-- 咨询按钮 -->
  <view class="contact-bar">
    <view class="contact-btn" bindtap="goToChat">
      <text class="contact-icon">💬</text>
      <text>立即咨询</text>
    </view>
    <view class="contact-phone" bindtap="makeCall">
      <text class="contact-icon">📞</text>
      <text>电话咨询</text>
    </view>
  </view>
</view>
