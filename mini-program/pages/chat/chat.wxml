<view class="chat-container">
  <!-- 头部提示 -->
  <view class="chat-header">
    <view class="header-icon">🤖</view>
    <view class="header-text">
      <text class="header-title">AI智能咨询助手</text>
      <text class="header-subtitle">5年经验 · 90%获奖率</text>
    </view>
  </view>

  <!-- AI生成声明 -->
  <view class="ai-disclaimer-banner">
    <text class="ai-disclaimer-icon">⚠️</text>
    <text class="ai-disclaimer-text">本页面由人工智能（AI）生成内容，仅供参考，不构成专业建议。</text>
  </view>

  <!-- 消息列表 -->
  <scroll-view 
    class="message-list" 
    scroll-y 
    scroll-into-view="{{scrollToMessage}}"
    enhanced
    show-scrollbar
  >
    <!-- 欢迎消息 -->
    <view class="message-item system-message" wx:if="{{showWelcome}}">
      <view class="message-content">
        <text class="welcome-title">👋 你好！我是你的奖项咨询助手</text>
        <text class="welcome-text">我可以帮你：</text>
        <view class="feature-list">
          <text class="feature-item">• 查询奖项费用、截止日期</text>
          <text class="feature-item">• 推荐适合你的奖项</text>
          <text class="feature-item">• 解答参赛流程疑问</text>
          <text class="feature-item">• 提供报奖策略建议</text>
        </view>
        <text class="welcome-tip">💡 试试问我："MUSE奖费用多少？" 或 "推荐个建筑类的奖"</text>
      </view>
    </view>

    <!-- 消息列表 -->
    <view 
      wx:for="{{messages}}" 
      wx:key="id" 
      id="msg-{{item.id}}"
      class="message-item {{item.type}}-message"
    >
      <!-- AI头像 -->
      <view class="avatar ai-avatar" wx:if="{{item.type === 'ai'}}">
        <text>🤖</text>
      </view>

      <!-- 消息内容 -->
      <view class="message-content">
        <!-- 文本消息 -->
        <block wx:if="{{item.contentType === 'text'}}">
          <text class="message-text">{{item.content}}</text>
          <view class="ai-generated-tag">AI生成</view>
        </block>

        <!-- 卡片消息（奖项信息） -->
        <block wx:if="{{item.contentType === 'award-card'}}">
          <view class="award-card-message">
            <view class="card-header">
              <text class="card-title">{{item.data.name_cn}}</text>
              <text class="card-subtitle">{{item.data.name_en}}</text>
            </view>
            <view class="card-body">
              <view class="info-row">
                <text class="info-label">参赛费用</text>
                <text class="info-value price">${{item.data.currentFee}}起</text>
              </view>
              <view class="info-row">
                <text class="info-label">最终截止</text>
                <text class="info-value highlight">{{item.data.deadline}} ({{item.data.daysLeft}}天)</text>
              </view>
              <view class="info-row">
                <text class="info-label">获奖率</text>
                <text class="info-value">{{item.data.win_rate}}</text>
              </view>
            </view>
            <view class="card-footer" bindtap="goToAwardDetail" data-id="{{item.data.id}}">
              <text>查看详情</text>
              <text class="arrow">→</text>
            </view>
          </view>
        </block>

        <!-- 列表消息 -->
        <block wx:if="{{item.contentType === 'list'}}">
          <text class="message-text">{{item.content}}</text>
          <view class="list-container">
            <view 
              wx:for="{{item.data}}" 
              wx:for-item="listItem"
              wx:key="index"
              class="list-item"
              bindtap="handleListItemTap"
              data-item="{{listItem}}"
            >
              <text class="list-item-text">{{listItem.name}}</text>
              <text class="list-item-arrow">→</text>
            </view>
          </view>
        </block>

        <!-- 时间戳 -->
        <text class="message-time">{{item.time}}</text>
      </view>

      <!-- 用户头像 -->
      <view class="avatar user-avatar" wx:if="{{item.type === 'user'}}">
        <text>👤</text>
      </view>
    </view>

    <!-- 底部占位 -->
    <view id="msg-bottom" style="height: 20rpx;"></view>
  </scroll-view>

  <!-- 快捷问题 -->
  <view class="quick-questions" wx:if="{{showQuickQuestions}}">
    <scroll-view scroll-x show-scrollbar="{{false}}">
      <view class="quick-questions-list">
        <view 
          wx:for="{{quickQuestions}}" 
          wx:key="index"
          class="quick-question-item"
          bindtap="sendQuickQuestion"
          data-question="{{item}}"
        >
          <text>{{item}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 输入区域 -->
  <view class="ai-disclaimer-footer">
    <text>以上回复由人工智能（AI）生成，内容仅供参考</text>
  </view>
  <view class="input-area">
    <view class="input-wrapper">
      <input 
        class="message-input"
        placeholder="输入你的问题..."
        placeholder-class="input-placeholder"
        value="{{inputValue}}"
        bindinput="onInputChange"
        bindconfirm="sendMessage"
        confirm-type="send"
        cursor-spacing="20"
      />
      <view 
        class="send-btn {{inputValue ? 'active' : ''}}"
        bindtap="sendMessage"
      >
        <text class="send-icon">➤</text>
      </view>
    </view>
  </view>

  <!-- 底部安全区域 -->
  <view class="safe-area-bottom"></view>
</view>
