/* 个人中心样式 */

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  margin: -20rpx -30rpx 30rpx;
  padding: 60rpx 30rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  position: relative;
  overflow: hidden;
}

.user-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(102, 126, 234, 0.3) 0%, transparent 70%);
  border-radius: 50%;
}

.user-avatar-large {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255,255,255,0.3);
  position: relative;
  z-index: 1;
}

.user-avatar-large open-data {
  width: 100%;
  height: 100%;
}

.user-info {
  flex: 1;
  position: relative;
  z-index: 1;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-role {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
}

.login-btn {
  background: rgba(255,255,255,0.2);
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  border: none;
  position: relative;
  z-index: 1;
}

.login-btn::after {
  border: none;
}

/* 统计卡片 */
.stats-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.stat-box {
  text-align: center;
}

.stat-number {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #667eea;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* 菜单卡片 */
.menu-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.menu-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.menu-list {
  display: flex;
  flex-direction: column;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item.highlight {
  background: rgba(102, 126, 234, 0.05);
  margin: 0 -20rpx;
  padding: 24rpx 20rpx;
  border-radius: 12rpx;
  border-bottom: none;
}

.menu-icon {
  width: 56rpx;
  height: 56rpx;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
}

.menu-item.highlight .menu-icon {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.menu-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.menu-badge {
  background: #f5576c;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 40rpx 0;
}

.version-info text {
  font-size: 24rpx;
  color: #999;
}
