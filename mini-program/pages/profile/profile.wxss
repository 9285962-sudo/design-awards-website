/* 关于我们页样式 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 160rpx;
}

.logo-section {
  background: linear-gradient(135deg, #1E3A5F 0%, #2d5a8e 100%);
  padding: 60rpx 30rpx;
  text-align: center;
  color: #fff;
}

.logo {
  font-size: 60rpx;
  font-weight: bold;
  letter-spacing: 8rpx;
  margin-bottom: 12rpx;
}

.tagline {
  font-size: 28rpx;
  opacity: 0.85;
  letter-spacing: 4rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  padding: 30rpx;
  margin-top: -40rpx;
}

.stat-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.07);
}

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #1E3A5F;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.section {
  background-color: #fff;
  margin: 0 30rpx 24rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1E3A5F;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #1E3A5F;
}

.about-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  margin-bottom: 16rpx;
  text-align: justify;
}

.scope-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.scope-tag {
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, #1E3A5F 0%, #2d5a8e 100%);
  color: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.contact-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background-color: #f8f9fc;
  border-radius: 12rpx;
}

.contact-icon {
  font-size: 40rpx;
}

.contact-info {
  flex: 1;
}

.contact-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.contact-value {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-top: 1rpx solid #eee;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.08);
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.action-btn.primary {
  background: linear-gradient(135deg, #1E3A5F, #2d5a8e);
  color: #fff;
}

.action-btn.secondary {
  background-color: #f0f0f0;
  color: #333;
}
