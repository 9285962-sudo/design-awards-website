<!-- 关于我们页 -->
<view class="container">
  <!-- Logo区 -->
  <view class="logo-section">
    <view class="logo">设计能</view>
    <view class="tagline">让设计被看见</view>
  </view>

  <!-- 核心数据 -->
  <view class="stats-grid">
    <view class="stat-card">
      <view class="stat-num">10+</view>
      <view class="stat-label">年行业经验</view>
    </view>
    <view class="stat-card">
      <view class="stat-num">108+</view>
      <view class="stat-label">全球合作奖项</view>
    </view>
    <view class="stat-card">
      <view class="stat-num">350+</view>
      <view class="stat-label">服务设计师</view>
    </view>
    <view class="stat-card">
      <view class="stat-num">80%</view>
      <view class="stat-label">平均获奖率</view>
    </view>
  </view>

  <!-- 公司介绍 -->
  <view class="section">
    <view class="section-title">关于设计能</view>
    <view class="about-text">
      深圳日光月华文化传播有限公司旗下的设计能品牌，专注国际设计大奖申报代理服务10年+，服务客户覆盖两岸四地350+设计公司及设计师。累计代理参赛作品1200+，帮助设计师斩获1000+国际设计大奖，平均获奖率高达80%。
    </view>
    <view class="about-text">
      我们代理包括德国iF设计奖、红点设计奖、美国IDEA奖、日本G-Mark奖、意大利A' Design奖、英国Dezeen Awards等在内的108个全球顶级设计大奖。
    </view>
  </view>

  <!-- 服务范围 -->
  <view class="section">
    <view class="section-title">服务范围</view>
    <view class="scope-tags">
      <text class="scope-tag" wx:for="{{scopes}}" wx:key="index">{{item}}</text>
    </view>
  </view>

  <!-- 联系方式 -->
  <view class="section">
    <view class="section-title">联系我们</view>
    <view class="contact-list">
      <view class="contact-item" bindtap="copyWechat">
        <view class="contact-icon">💬</view>
        <view class="contact-info">
          <view class="contact-label">微信公众号</view>
          <view class="contact-value">设计能</view>
        </view>
      </view>
      <view class="contact-item" bindtap="makePhoneCall">
        <view class="contact-icon">📞</view>
        <view class="contact-info">
          <view class="contact-label">联系电话</view>
          <view class="contact-value">13692222744 何先生</view>
        </view>
      </view>
      <view class="contact-item" bindtap="copyEmail">
        <view class="contact-icon">✉️</view>
        <view class="contact-info">
          <view class="contact-label">电子邮箱</view>
          <view class="contact-value">9285962@qq.com</view>
        </view>
      </view>
      <view class="contact-item" bindtap="openWebsite">
        <view class="contact-icon">🌐</view>
        <view class="contact-info">
          <view class="contact-label">官方网站</view>
          <view class="contact-value">www.52de.cc</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 咨询按钮 -->
  <view class="action-bar">
    <view class="action-btn primary" bindtap="goToService">
      <text>了解服务</text>
    </view>
    <view class="action-btn secondary" bindtap="makePhoneCall">
      <text>电话咨询</text>
    </view>
  </view>
</view>
