.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding: 20rpx;
  box-sizing: border-box;
}

/* 搜索栏 */
.search-bar {
  margin-bottom: 20rpx;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 40rpx;
  padding: 20rpx 30rpx;
  backdrop-filter: blur(10px);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  opacity: 0.7;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #fff;
}

.search-input::placeholder {
  color: rgba(255, 255, 255, 0.5);
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 30rpx;
  overflow-x: auto;
  padding-bottom: 10rpx;
}

.filter-item {
  padding: 16rpx 32rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 32rpx;
  white-space: nowrap;
  transition: all 0.3s ease;
}

.filter-item text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.filter-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.filter-item.active text {
  color: #fff;
  font-weight: 500;
}

/* 奖项列表 */
.award-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.award-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.2s ease;
}

.award-card:active {
  transform: scale(0.98);
}

.award-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.award-logo {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.logo-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.award-info {
  flex: 1;
}

.award-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
  margin-bottom: 6rpx;
}

.award-name-en {
  font-size: 24rpx;
  color: #888;
}

.award-badge {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.badge-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
}

/* 标签 */
.award-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.tag-primary {
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
}

.tag-success {
  background: rgba(82, 196, 26, 0.1);
  color: #52c41a;
}

.tag-warning {
  background: rgba(250, 173, 20, 0.1);
  color: #faad14;
}

/* 描述 */
.award-desc {
  margin-bottom: 20rpx;
  padding: 16rpx;
  background: rgba(102, 126, 234, 0.05);
  border-radius: 12rpx;
}

.desc-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

/* 底部信息 */
.award-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.fee-info, .deadline-info {
  display: flex;
  flex-direction: column;
}

.fee-label, .deadline-label {
  font-size: 22rpx;
  color: #888;
  margin-bottom: 4rpx;
}

.fee-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #667eea;
}

.deadline-value {
  font-size: 24rpx;
  color: #f5576c;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

.safe-area-bottom {
  height: 40rpx;
}
